# Copy to .env and fill in. .env is gitignored.

# SEMRush API key. Required ONLY when SEMRUSH_LIVE=true. Otherwise FakeSemRushClient is used.
SEMRUSH_API_KEY=

# DANGER: flips on real SEMRush calls. We have 50,000 credits this month for the WHOLE TEAM.
# Keep this `false` during dev. Set `true` only for the live demo or an explicit smoke test.
SEMRUSH_LIVE=false

# Host port for Postgres. Override (e.g. 5433) if 5432 is already in use locally.
POSTGRES_PORT=5432
